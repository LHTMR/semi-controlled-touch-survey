dal\n\tvar btn9 = document.getElementById(\"myBtn9\");\n\n\t\/\/ Get the <span> element that closes the modal\n\tvar span9 = document.getElementsByClassName(\"close\")[5];\n\n\t\/\/ When the user clicks on the button, open the modal\n\tbtn9.onclick = function() {\n  \t\tmodal9.style.display = \"block\";\n\t}\n\n\t\/\/ When the user clicks on <span> (x), close the modal\n\tspan9.onclick = function() {\n  \t\tmodal9.style.display = \"none\";\n\t}\n\n\t\/\/ When the user clicks anywhere outside of the modal, close it\n\twindow.onclick = function(event) {\n  \t\tif (event.target == modal9) {\n    \tmodal9.style.display = \"none\";\n  \t}\n\t\n}\t\n\t\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What part of your body does the person touch?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":{"DE":{"QuestionText":"<h3><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Jetzt stellen Sie sich bitte eine soziale Interaktion vor, in der Sie auf diese Art ber\u00fchrt werden.<\/span><\/h3>\n\n<p><br \/>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Bedenken Sie dabei die folgenden Details<\/span><\/p>\n\n<div class=\"row\">\n<div class=\"column\">\n<ul>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Welcher<button id=\"myBtn4\">Bereich Ihres K\u00f6rpers<\/button> wird ber\u00fchrt?<\/span><\/li>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><button id=\"myBtn2\">Wo<\/button>sind Sie?<\/s