Horror, Interesse, Langeweile, Neid, Nostalgie, Romantik, Ruhe, Schmerz, Schuld, sexuelles, Stolz, Sympathie, Traurigkeit, Triumph, \u00dcberraschung, Unbeholfenheit, Verachtung, Verlangen, Verlangen, Verwirrung, Wertsch\u00e4tzung, Wut, Zufriedenheit, \u00c4sthetische\u2026<\/span><\/p>\n<\/div>\n<\/div>\n"}},"NextChoiceId":90,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID743"}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"How do you identify yourself?","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">How do you identify yourself?<\/span><\/p>","DefaultChoices":false,"DataExportTag":"Gender","QuestionType":"MC","Selector":"SAVR","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How do you identify yourself?","Choices":{"1":{"Display":"Male"},"2":{"Display":"Female"},"3":{"Display":"Non-binary \/ third gender"},"4":{"Display":"Prefer to self-describe","TextEntry":"true","TextEntryValidation":"ValidTextOnly","TextEntryForceResponse":true},"5":{"Display":"Rather not say"}},"ChoiceOrder":[1,2,3,5,4],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID6\/SelectableChoice\/4","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">How do you identify yourself?<\/span> <span class=\"LeftOpDesc\">Prefer to self-describe<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID6\/SelectableChoice\/4","LogicType":"Question","Operator":"Selected","QuestionID":"QID6","QuestionIDFromLocator":"QID6","QuestionIsInLoop":"no","Type":"Expression"},"1":{"ChoiceLocator":"q:\/\/QID6\/ChoiceTextEntryValue\/4","Conjuction":"And","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">How do you identify yourself?<\/span> <span class=