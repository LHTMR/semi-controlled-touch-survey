esponse":"false"},"QuestionID":"QID351","QuestionJS":false,"DataVisibility":{"Private":false,"Hidden":false},"DisplayLogic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID369\/SelectableChoice\/2","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">Would you be willing to continue watching another video and answer its set of questions, like you...<\/span> <span class=\"LeftOpDesc\">NO, I would like to finish the survey now.<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID369\/SelectableChoice\/2","LogicType":"Question","LoopAndMergeLoops":"current","LoopTarget":"none","Operator":"Selected","QuestionID":"QID369","QuestionIDFromLocator":"QID369","QuestionIsInLoop":"yes","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression","inPage":false}}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID749","SecondaryAttribute":"Thank you for taking part in this study. Please, click the button below to be redirected back to...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for taking part in this study. Please, click the button below to be redirected back to Prolific and register your submission.","DefaultChoices":false,"DataExportTag":"Q376","QuestionType":"TE","Selector":"ML","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for taking part in this study. Please, click the button below to be redirected back to...","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID749","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID747","SecondaryAttribute":"Thank you for taking part in this survey.","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for taking part in this survey.<br>","DefaultChoices":false,"DataExportTag":"Q374","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for taking part in this survey.","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID747"}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID361","SecondaryAttribute":"The aim\u00a0 of this online study is to observe how different ways of touching influence our descript..","TertiaryAttribute":null,"Payload":{"QuestionText":"<h2 style=\"text-align: center;\"><strong>The aim&nbsp;<\/strong><\/h2>\n\n<h4 style=\"text-align: center;\"><span style=\"font-size:16px;\">of this online study is to observe how different ways of touching influence our description of social touch interactions.<\/span><\/h4>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<h4 style=\"text-align: center;\"><span style=\"font-size:16px;\">Your participation will allow us to<strong> better understand how we communicate through touch.<\/strong><\/span><\/h4>\n\n<div style=\"text-align: left;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-size:19px;\">&nbsp;<strong>With your help, we will be able to<span style=\"font-size:16px;\"><strong> <\/strong><\/span>create a vocabulary of social touch communication!<\/strong><\/span><\/div>","DefaultChoices":false,"DataExportTag":"Aim","QuestionID":"QID361","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The aim\u00a0 of this online study is to observe how different ways of touching influence our descript...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":1}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID729","SecondaryAttribute":"UK Ethnic Origin","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5,6],"Choices":{"1":{"Display":"White"},"2":{"Display":"Black\/African\/Caribbean"},"3":{"Display":"Asian (Indian, Pakistani, Bangladeshi, Chinese, any other Asian background)"},"4":{"Display":"Mixed two or more ethnic groups"},"5":{"Display":"Other (Arab or any others)"},"6":{"Display":"Prefer not to say"}},"Configuration":{"QuestionDescriptionOption":"SpecifyLabel"},"DataVisibility":{"Hidden":false,"Private":false},"Language":{"DE":{"Choices":{"1":{"Display":"Wei\u00df"},"2":{"Display":"Schwarz\/Afrikanisch\/Karibisch"},"3":{"Display":"Asiatisch (Indisch, Pakistani, Bangladeschisch, Chinesisch, sonstiger asiatischer Hintergrund)"},"4":{"Display":"Zwei oder mehr ethnische Gruppen gemischt"},"5":{"Display":"Sonstige (arabisch oder andere)"},"6":{"Display":"Keine Angabe"}},"QuestionText":"Wie l\u00e4sst sich Ihre ethnische Zugeh\u00f6rigkeit am besten beschreiben?"},"EN-GB":{"Choices":{"1":{"Display":"White"},"2":{"Display":"Black\/African\/Caribbean"},"3":{"Display":"Asian (Indian, Pakistani, Bangladeshi, Chinese, any other Asian background)"},"4":{"Display":"Mixed two or more ethnic groups"},"5":{"Display":"Other (Arab or any others)"},"6":{"Display":"Prefer not to say"}},"QuestionText":"What best describes your ethnic origin?"},"ES":{"Choices":{"1":{"Display":"Blanco"},"2":{"Display":"Blanco\/Africano\/Caribe\u00f1o"},"3":{"Display":"Asi\u00e1tico (indio, paquistan\u00ed, bangladesh\u00ed, chino y cualquier otro origen asi\u00e1tico)"},"4":{"Display":"Combinaci\u00f3n de dos o m\u00e1s grupos \u00e9tnicos"},"5":{"Display":"Otro (\u00e1rabe o cualquier otro)"},"6":{"Display":"Prefiero no decirlo"}},"QuestionText":"\u00bfQu\u00e9 describe mejor su origen \u00e9tnico?"},"ES-ES":{"Choices":{"1":{"Display":"Blanco"},"2":{"Display":"Blanco\/Africano\/Caribe\u00f1o"},"3":{"Display":"Asi\u00e1tico (indio, paquistan\u00ed, banglades\u00ed, chino y cualquier otro de ascendencia asi\u00e1tica)"},"4":{"Display":"Mezcla de dos o m\u00e1s grupos \u00e9tnicos"},"5":{"Display":"Otro (\u00e1rabe u otros)"},"6":{"Display":"Prefiero no decirlo"}},"QuestionText":"\u00bfQu\u00e9 es lo que mejor describe su origen \u00e9tnico?"},"FR":{"Choices":{"1":{"Display":"Blanc"},"2":{"Display":"Noir\/Africain\/Carib\u00e9en"},"3":{"Display":"Asiatique (Indien, Pakistanais, Bangladais, Chinois ou autre origine asiatique)"},"4":{"Display":"Deux groupes ethniques ou plus"},"5":{"Display":"Autre groupe ethnique (Arabe ou autres)"},"6":{"Display":"Ne souhaite pas r\u00e9pondre"}},"QuestionText":"Qu'est-ce qui d\u00e9crit le mieux votre origine ethnique\u00a0?"},"IT":{"Choices":{"1":{"Display":"Bianco\/a"},"2":{"Display":"Nero\/a \/ Africano\/a \/ Caraibico\/a"},"3":{"Display":"Asiatico\/a (indiano\/a, pakistano\/a, bangladese, cinese, qualsiasi altra origine asiatica)"},"4":{"Display":"Misto (due o pi\u00f9 gruppi etnici)"},"5":{"Display":"Altro (arabo o altro)"},"6":{"Display":"Preferisco non dirlo"}},"QuestionText":"Qual'\u00e8 l'aspetto che descrive meglio le tue origini etniche?"},"JA":{"Choices":{"1":{"Display":"\u767d\u4eba"},"2":{"Display":"\u9ed2\u4eba\uff0f\u30a2\u30d5\u30ea\u30ab\u7cfb\u30fb\u30ab\u30ea\u30d6\u7cfb"},"3":{"Display":"\u30a2\u30b8\u30a2\u7cfb\uff08\u30a4\u30f3\u30c9\u3001\u30d1\u30ad\u30b9\u30bf\u30f3\u3001\u30d0\u30f3\u30b0\u30e9\u30c7\u30b7\u30e5\u3001\u4e2d\u56fd\u3001\u305d\u306e\u4ed6\u306e\u30a2\u30b8\u30a2\u7cfb\u30d0\u30c3\u30af\u30b0\u30e9\u30a6\u30f3\u30c9\uff09"},"4":{"Display":"2\u3064\u4ee5\u4e0a\u306e\u6c11\u65cf\u30b0\u30eb\u30fc\u30d7\u306b\u307e\u305f\u304c\u308b\u4eba"},"5":{"Display":"\u305d\u306e\u4ed6\uff08\u30a2\u30e9\u30d6\u307e\u305f\u306f\u305d\u306e\u4ed6\uff09"},"6":{"Display":"\u56de\u7b54\u3057\u305f\u304f\u306a\u3044"}},"QuestionText":"\u3042\u306a\u305f\u306e\u6c11\u65cf\u7684\u51fa\u8eab\u3092\u8868\u3059\u8a00\u8449\u3068\u3057\u3066\u6700\u3082\u8fd1\u3044\u3082\u306e\u3092\u9078\u3093\u3067\u304f\u3060\u3055\u3044\u3002"},"KO":{"Choices":{"1":{"Display":"\ubc31\uc778"},"2":{"Display":"\ud751\uc778\/\uc544\ud504\ub9ac\uce74\uc778\/\uce74\ub9ac\ube0c\ud574\uc778"},"3":{"Display":"\uc544\uc2dc\uc544\uc778(\uc778\ub3c4\uc778, \ud30c\ud0a4\uc2a4\ud0c4\uc778, \ubc29\uae00\ub77c\ub370\uc2dc\uc778, \uc911\uad6d\uc778, \uae30\ud0c0 \uc544\uc2dc\uc544 \ubc30\uacbd)"},"4":{"Display":"\ub458 \uc774\uc0c1\uc758 \ud63c\ud608 \ubbfc\uc871 \uadf8\ub8f9"},"5":{"Display":"\uae30\ud0c0(\uc544\ub78d \ub610\ub294 \uae30\ud0c0)"},"6":{"Display":"\uc5b8\uae09 \uc548 \ud568"}},"QuestionText":"\ubbfc\uc871 \ud0dc\uc0dd\uc744 \uac00\uc7a5 \uc798 \uc124\uba85\ud55c \uac83\uc740 \ubb34\uc5c7\uc785\ub2c8\uae4c?"},"NL":{"Choices":{"1":{"Display":"Wit"},"2":{"Display":"Zwart\/Afrikaans\/Cara\u00efbisch"},"3":{"Display":"Aziatische (Indiase, Pakistaanse, Bengalese, Chinese of overige Aziatische achtergrond) afkomst"},"4":{"Display":"Van gemengde etnische afkomst"},"5":{"Display":"Anders (Arabisch of andere)"},"6":{"Display":"Ik antwoord liever niet"}},"QuestionText":"Hoe zou u uw etnische afkomst omschrijven?"},"PT-BR":{"Choices":{"1":{"Display":"Branco"},"2":{"Display":"Preto\/Africano\/Caribenho"},"3":{"Display":"Asi\u00e1tico (indianos, paquistaneses, bengali, chineses e qualquer outra descend\u00eancia asi\u00e1tica)"},"4":{"Display":"Composi\u00e7\u00e3o de dois ou mais grupos \u00e9tnicos"},"5":{"Display":"Outro (\u00e1rabe ou qualquer outro)"},"6":{"Display":"Prefiro n\u00e3o dizer"}},"QuestionText":"O que melhor descreve a sua origem \u00e9tnica?"},"ZH-S":{"Choices":{"1":{"Display":"\u767d\u4eba"},"2":{"Display":"\u9ed1\u4eba\/\u975e\u6d32\u4eba\/\u52a0\u52d2\u6bd4\u6d77\u4eba"},"3":{"Display":"\u4e9a\u88d4\uff08\u5370\u88d4\u3001\u5df4\u57fa\u65af\u5766\u88d4\u3001\u5b5f\u52a0\u62c9\u88d4\u3001\u534e\u88d4\u3001\u4efb\u4f55\u5176\u4ed6\u4e9a\u88d4\u80cc\u666f\uff09"},"4":{"Display":"\u4e24\u4e2a\u6216\u4ee5\u4e0a\u6c11\u65cf\u6df7\u5408"},"5":{"Display":"\u5176\u4ed6\uff08\u963f\u62c9\u4f2f\u4eba\u6216\u4efb\u4f55\u5176\u4ed6\u4eba\uff09"},"6":{"Display":"\u4fdd\u5bc6"}},"QuestionText":"\u54ea\u4e00\u9879\u6700\u80fd\u63cf\u8ff0\u60a8\u7684\u79cd\u65cf\u672c\u6e90\uff1f"},"ZH-T":{"Choices":{"1":{"Display":"\u767d\u4eba"},"2":{"Display":"\u9ed1\u4eba\/\u975e\u88d4\/\u52a0\u52d2\u6bd4\u88d4"},"3":{"Display":"\u4e9e\u88d4 (\u5370\u5ea6\u88d4\u3001\u5df4\u57fa\u65af\u5766\u88d4\u3001\u5b5f\u52a0\u62c9\u88d4\u3001\u83ef\u88d4\u3001\u5176\u4ed6\u4e9e\u88d4\u80cc\u666f)"},"4":{"Display":"\u6df7\u6709\u4e8c\u6216\u591a\u500b\u7a2e\u65cf"},"5":{"Display":"\u5176\u4ed6 (\u963f\u62c9\u4f2f\u88d4\u6216\u5176\u4ed6)"},"6":{"Display":"\u4e0d\u9858\u900f\u9732"}},"QuestionText":"\u4ee5\u4e0b\u54ea\u4e00\u9805\u6700\u80fd\u6e96\u78ba\u63cf\u8ff0\u60a8\u7684\u7a2e\u65cf\uff1f"}},"NextAnswerId":1,"NextChoiceId":7,"QuestionDescription":"UK Ethnic Origin","QuestionText":"What best describes your ethnic origin?","QuestionText_Unsafe":"What best describes your ethnic origin?","QuestionType":"MC","ReferenceQuestionConfig":{"instanceOf":{"id":"RQ_DJccia0wtvq2zIe","version":"v2.0.0"}},"SchemaConfig":{"ChoiceMapping":{"1":"enu:\/\/UKWhite","2":"enu:\/\/UKBlackAfricanCaribbean","3":"enu:\/\/UKAsian","4":"enu:\/\/UKMixedTwoOrMoreEthnicGroups","5":"enu:\/\/UKOtherEthnicGroup","6":"enu:\/\/PreferNotToSay"},"ChoiceMappingType":"Member","ConfigVersion":"1.0.0","Reconfirm":true,"URL":"ses:\/\/UKEthnicOrigin","XMDConnect":true},"Selector":"MAVR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"DataExportTag":"Q729","QuestionID":"QID729"}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Welcome to this online survey on social touch! The survey takes around 10 minutes,","TertiaryAttribute":null,"Payload":{"QuestionText":"<h1 style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><span style=\"font-size:29px;\"><span style=\"color:#2c3e50;\"><strong>Welcome to the online survey of social touch!<\/strong><\/span><\/span><\/span><\/h1>\n\n<p>&nbsp;<\/p>\n\n<div style=\"text-align: center;\"><br>\n<span style=\"font-size:16px;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><span lang=\"EN-AU\"><span style=\"color:black\">By participating in this survey, you are helping us to understand social touch, and the link between how it is performed and how it is interpreted<\/span><\/span>.<\/span><\/span><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><span style=\"font-size: 16px; text-align: center;\">The survey takes around 3-10 minutes, and we will ask you to do the following:<\/span><\/span><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><span style=\"font-size:12pt\"><span lang=\"EN-US\"><span style=\"color:black\">1.&nbsp;<\/span><\/span><span style=\"color:black\">Provide some basic information<\/span><\/span><br>\n<span style=\"font-size:12pt\"><span lang=\"EN-US\"><span style=\"color:black\">2.<\/span><\/span><span style=\"color:black\"> Watch a short video clip of social touch<\/span><\/span><br>\n<span style=\"font-size:12pt\"><span lang=\"EN-US\"><span style=\"color:black\">3.<\/span><\/span><span style=\"color:black\">&nbsp;Describe the touch in different ways<\/span><\/span><br>\n<span style=\"font-size:12pt\"><span lang=\"EN-US\"><span style=\"color:black\">4.<\/span><\/span><span style=\"color:black\">&nbsp;Answer some questions regarding the touch you described<\/span><\/span><br>\n<\/span><\/div><div style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><span style=\"font-size:12pt\"><span lang=\"EN-US\"><span style=\"color:black\">5. Optionally repeat steps 2-4 with new videos.<br><\/span><\/span><\/span><\/span><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">&nbsp;&nbsp;<\/span>\n\n<div>&nbsp;<\/div>\n\n<div>&nbsp;<\/div>","DefaultChoices":false,"DataExportTag":"Welcome","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"SpecifyLabel"},"QuestionDescription":"Welcome to this online survey on social touch! The survey takes around 10 minutes,","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"DE":{"QuestionText":"<h1 style=\"text-align: center;\"><span style=\"font-size:22px;\"><span style=\"font-family:Arial,Helvetica,sans-serif;\"><strong><span lang=\"EN-US\"><span unicode=\"\"><span style=\"color:#2c3e50\">Herzlich willkommen zu dieser Online-Studie zum Thema Soziale Ber\u00fchrung!<\/span><\/span><\/span><\/strong><\/span><\/span><\/h1>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-size: 16px; text-align: center;\">Die Umfrage dauert etwa 3-10 Minuten, und wir werden Sie bitten:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:16px;\">\u2022 Einige allgemeine Fragen zu ihrer Person zu beantworten<\/span><\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-size: 16px;\">\u2022 Sich ein Video anzusehen, in dem eine soziale Ber\u00fchrung gezeigt wird\u00a0<\/span><\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-size: 16px;\">\u2022 Dieser Ber\u00fchrung auf verschiedene Arten zu Beschreiben<\/span><\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-size: 16px;\">\u2022 Einige wenige spezifischere Nachfragen, zu der von Ihnen beschriebenen Ber\u00fchrung zu beantworten<\/span><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<h2 style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><span style=\"color:#2c3e50;\"><strong>Ihre Antworten werden uns helfen ein Lexikon der sozialen Ber\u00fchrungen zu gestalten.<\/strong><\/span><\/span><\/h2>\n\u00a0\n\n<p style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><button id=\"myBtn99\">Warum interessiert uns das?<\/button><\/span><\/p>\n\u00a0\u00a0\n\n<h3 style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><strong>Bitte versuchen Sie, sich auf die gezeigten Ber\u00fchrungen zu konzentrieren und die folgenden Fragen so genau wie m\u00f6glich zu beantworten.<\/strong><\/span><\/h3>\n\n<div>\u00a0<\/div>\n\n<div class=\"modal\" id=\"myModal99\">\n<div class=\"modal-content\">\n<div class=\"modal-header\"><span class=\"close\">\u00d7<\/span><\/div>\n\n<p style=\"text-align: center;\"><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Ber\u00fchrung ist ein wichtiger Bestandteil sozialer Interaktion und ein n\u00fctzliches Werkzeug, um miteinander zu kommunizieren. Verschiedene Merkmale von Ber\u00fchrungen k\u00f6nnen beim Empf\u00e4nger sehr unterschiedliche Gedanken und Gef\u00fchle hervorrufen. Wir wissen jedoch wenig dar\u00fcber, welche Rolle die einzelnen physischen Eigenschaften einer Ber\u00fchrung dabei spielen. Ziel dieser Online-Studie ist es, zu untersuchen, wie die Ver\u00e4nderung einzelner Ber\u00fchrungseigenschaften die Beschreibung einer sozialen taktilen Interaktion beeinflusst. Ihre Teilnahme wird es uns erm\u00f6glichen, besser zu verstehen, wie wir durch taktile Interaktion kommunizieren und wie verschiedene Ber\u00fchrungsmerkmale die \u00fcbermittelten Informationen beeinflussen. Das wird uns helfen, ein Lexikon der sozialen taktilen Kommunikation zu gestalten.<\/span><\/p>\n<\/div>\n<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionJS":false}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID398","SecondaryAttribute":"What do you think is the intention and purpose of the person who is giving the touch in this video?","TertiaryAttribute":null,"Payload":{"QuestionText":"What do you think is the intention and purpose of<em> the person who is giving the touch<\/em> in this video?","DefaultChoices":false,"QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What do you think is the intention and purpose of the person who is giving the touch in this video?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"What do you think is the intention and purpose of<em> the person who is giving the touch<\/em> in this video?","DataExportTag":"Q398","QuestionID":"QID398"}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute":"QID410","SecondaryAttribute":"What do you think is the intention and purpose of the person who is giving the touch in this video?","TertiaryAttribute":null,"Payload":{"QuestionText":"What do you think is the intention and purpose of<em> the person who is giving the touch<\/em> in this video?","DefaultChoices":false,"QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What do you think is the intention and purpose of the person who is giving the touch in this video?","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"What do you think is the intention and purpose of<em> the person who is giving the touch<\/em> in this video?","DataExportTag":"Q410","QuestionID":"QID410"}},{"SurveyID":"SV_82HJZMMWolInCCi","Element":"SQ","PrimaryAttribute"