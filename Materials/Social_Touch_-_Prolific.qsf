function(event) {\n  \t\tif (event.target == modal9) {\n    \tmodal9.style.display = \"none\";\n  \t}\n\t\n}\t\n\t\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"TE","Selector":"ESTB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What part of your body does the person touch? (it can be anywhere, besides the forearm)","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":{"DE":{"QuestionText":"<h3><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Jetzt stellen Sie sich bitte eine soziale Interaktion vor, in der Sie auf diese Art ber\u00fchrt werden.<\/span><\/h3>\n\n<p><br \/>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Bedenken Sie dabei die folgenden Details<\/span><\/p>\n\n<div class=\"row\">\n<div class=\"column\">\n<ul>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Welcher<button id=\"myBtn4\">Bereich Ihres K\u00f6rpers<\/button> wird ber\u00fchrt?<\/span><\/li>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><button id=\"myBtn2\">Wo<\/button>sind Sie?<\/span><\/li>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><button id=\"myBtn3\">Wer<\/button>ist die Person, die Sie ber\u00fchrt?<\/span><\/li>\n<\/ul>\n<\/div>\n\n<div class=\"column\">\n<ul>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><button id=\"myBtn5\">Was<\/button>tun Sie gerade?<\/span><\/li>\n\t<li><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Was ist die Absicht der Person, die Sie ber